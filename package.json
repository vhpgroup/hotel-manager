{
  "name": "hotel-manager",
  "productName": "StayPro",
  "version": "1.0.0",
  "description": "StayPro - Phần mềm quản lý khách sạn (desktop app, Electron + SQLite). Chạy được cả dạng web.",
  "main": "electron/main.js",
  "author": "vhpgroup",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "electron .",
    "web": "node --disable-warning=ExperimentalWarning server.js",
    "dev": "node --disable-warning=ExperimentalWarning --watch server.js",
    "seed": "node --disable-warning=ExperimentalWarning db.js --reseed",
    "test": "node test.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "icon": "node build/gen-icon.js",
    "postinstall": "node build/gen-icon.js"
  },
  "keywords": ["hotel", "khach-san", "kiotviet", "pms", "electron", "desktop", "sqlite"],
  "dependencies": {},
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vhpgroup.staypro",
    "productName": "StayPro",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**",
      "lib/**",
      "routes/**",
      "public/**",
      "build/icon.png",
      "server.js",
      "db.js",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png",
      "artifactName": "StayPro-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StayPro"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Office"
    }
  }
}
